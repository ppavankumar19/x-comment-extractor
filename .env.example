APP_NAME=X Comment Extractor
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

LLM_ENABLED=true
LLM_BACKEND=nvidia

NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=1.0
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=16384
NVIDIA_REASONING_BUDGET=16384
NVIDIA_ENABLE_THINKING=true
NVIDIA_TIMEOUT_SECONDS=45

SCRAPE_TIMEOUT_MS=120000
SCRAPE_SCROLL_PAUSE_MS=2200
SCRAPE_MAX_SCROLLS=120
SCRAPE_IDLE_ROUNDS=8
PLAYWRIGHT_HEADLESS=true

X_STORAGE_STATE_PATH=playwright/storage_state.json
X_LOGIN_URL=https://x.com/i/flow/login
X_AUTH_TOKEN=
X_CT0=

USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
